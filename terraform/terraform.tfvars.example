# =============================================================================
# TERRAFORM.TFVARS.EXAMPLE — Committable template (no real values)
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real secrets or IPs.
# =============================================================================

project_name          = "devops-terraform-api"
environment           = "portfolio"
region                = "us-east-1"
vpc_cidr              = "10.0.0.0/16"
public_subnet_cidr    = "10.0.1.0/24"
private_subnet_cidr   = "10.0.2.0/24"
az_a                  = "us-east-1a"
az_b                  = "us-east-1b"
instance_type         = "t2.micro"
key_name              = "devops-terraform-key"
app_port              = 5000

# ⚠️  Replace with your actual public IP (curl https://checkip.amazonaws.com)
allowed_ssh_cidr      = "CHANGE_ME_YOUR_IP/32"
